---
import { getRandomMessage } from '../lib/messages';

const greeting = getRandomMessage();
---

<section class="hero">
  <div class="hero__inner">
    <h1 class="hero__greeting">{greeting}</h1>
    <p class="hero__sub">i'm tat — i build things for the web</p>
    <a href="https://resume.bytat.dev" class="hero__cta" target="_blank" rel="noopener noreferrer">
      see my resume
      <span class="hero__cta-arrow" aria-hidden="true">→</span>
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    min-height: 100vh;
    min-height: 100dvh;
    padding: 3rem 4rem 6rem;
    pointer-events: none;
  }

  .hero__inner {
    max-width: 42rem;
    pointer-events: auto;    text-shadow: 0 2px 30px rgba(15, 13, 10, 0.9), 0 0 80px rgba(15, 13, 10, 0.6);  }

  /* --- Greeting --- */
  .hero__greeting {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(3rem, 8vw, 6.5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-cream);
    text-transform: lowercase;
    opacity: 0;
    transform: translateY(28px);
    animation: fade-up 0.9s var(--ease-out-expo) 0.3s forwards;
  }

  /* --- Subtext --- */
  .hero__sub {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.1rem, 2.2vw, 1.5rem);
    line-height: 1.5;
    color: var(--color-sand);
    margin-top: 1rem;
    opacity: 0;
    transform: translateY(20px);
    animation: fade-up 0.9s var(--ease-out-expo) 0.55s forwards;
  }

  /* --- CTA --- */
  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 2.2rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    color: var(--color-cream);
    padding: 0.8rem 0;
    position: relative;
    text-decoration: none;
    opacity: 0;
    transform: translateY(16px);
    animation: fade-up 0.9s var(--ease-out-expo) 0.8s forwards;
  }

  .hero__cta::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s var(--ease-out-expo);
  }

  .hero__cta:hover::after,
  .hero__cta:focus-visible::after {
    transform: scaleX(1);
  }

  .hero__cta-arrow {
    display: inline-block;
    transition: transform 0.4s var(--ease-out-expo);
  }

  .hero__cta:hover .hero__cta-arrow,
  .hero__cta:focus-visible .hero__cta-arrow {
    transform: translateX(4px);
  }

  .hero__cta:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 6px;
    border-radius: 2px;
  }

  /* --- Entrance animation --- */
  @keyframes fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* --- Mobile --- */
  @media (max-width: 640px) {
    .hero {
      padding: 2rem 1.5rem 4rem;
      align-items: center;
    }
  }
</style>
