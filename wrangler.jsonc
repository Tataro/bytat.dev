{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "bytat-dev",
  "main": "dist/_worker.js",
  "compatibility_date": "2026-03-11",
  "compatibility_flags": ["nodejs_compat_v2"],
  "workers_dev": false,
  "routes": [
    { "pattern": "bytat.dev", "custom_domain": true },
    { "pattern": "www.bytat.dev", "custom_domain": true },
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
}
